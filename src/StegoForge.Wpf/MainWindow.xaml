<Window x:Class="StegoForge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:StegoForge.Wpf.Views"
        mc:Ignorable="d"
        Title="StegoForge"
        Height="600"
        Width="900"
        MinHeight="500"
        MinWidth="750">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>

        <TabControl Margin="12">
            <TabItem Header="Embed">
                <views:EmbedView DataContext="{Binding Embed}" />
            </TabItem>
            <TabItem Header="Extract">
                <views:ExtractView DataContext="{Binding Extract}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
