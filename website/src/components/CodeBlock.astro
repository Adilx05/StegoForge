---
interface Props {
  code: string;
}

const { code } = Astro.props;
---

<pre><code>{code}</code></pre>

<style>
  pre {
    margin: 0;
    background: #020617;
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
  }

  code {
    font-size: 0.9rem;
    color: #e2e8f0;
  }
</style>
