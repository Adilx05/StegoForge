---
interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  subheadline: string;
  primaryCta: Cta;
  secondaryCta: Cta;
}

const { eyebrow, headline, subheadline, primaryCta, secondaryCta } = Astro.props;
---

<section id="hero" class="hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{headline}</h1>
  <p class="lead">{subheadline}</p>
  <div class="actions">
    <a href={primaryCta.href} class="cta primary">{primaryCta.label}</a>
    <a href={secondaryCta.href} class="cta secondary">{secondaryCta.label}</a>
  </div>
</section>
