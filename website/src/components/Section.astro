---
interface Props {
  id: string;
  title: string;
  lead?: string;
}

const { id, title, lead } = Astro.props;
---

<section id={id} class="section">
  <div class="section-header">
    <h2>{title}</h2>
    {lead && <p>{lead}</p>}
  </div>
  <div class="section-content">
    <slot />
  </div>
</section>
