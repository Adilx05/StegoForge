---
const title = 'StegoForge';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p>Astro + TypeScript scaffold configured for GitHub Pages.</p>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: system-ui, sans-serif;
    background: #0b1020;
    color: #f8fafc;
  }

  main {
    min-height: 100vh;
    display: grid;
    place-content: center;
    gap: 0.75rem;
    text-align: center;
    padding: 2rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3rem);
  }

  p {
    margin: 0;
    color: #cbd5e1;
  }
</style>
