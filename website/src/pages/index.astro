---
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';
import { siteContent } from '../content/site';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>StegoForge</title>
  </head>
  <body>
    <header>
      <nav aria-label="Section navigation">
        <a href="#hero">Hero</a>
        <a href="#overview">Overview</a>
        <a href="#features">Features</a>
        <a href="#formats">Formats</a>
        <a href="#cli">CLI</a>
        <a href="#wpf">WPF</a>
        <a href="#getting-started">Install</a>
        <a href="#download">Download</a>
        <a href="#roadmap">Roadmap</a>
        <a href="#faq">FAQ</a>
        <a href="#footer">Footer</a>
      </nav>
    </header>

    <main>
      <Hero {...siteContent.hero} />

      <Section id="overview" title="Project overview" lead={siteContent.overviewLead}>
        <ul>
          <li>Core contracts in <code>StegoForge.Core</code> define service and payload models.</li>
          <li><code>StegoForge.Application</code> coordinates embed, extract, capacity, and info orchestration.</li>
          <li>Delivery surfaces include a scriptable CLI and a WPF desktop app.</li>
        </ul>
      </Section>

      <Section id="features" title="Feature highlights" lead={siteContent.featuresLead}>
        <FeatureGrid items={siteContent.features} />
      </Section>

      <Section id="formats" title="Supported formats" lead="Production handlers currently wired through full workflows.">
        <ul>
          <li><strong>PNG</strong>: <code>png-lsb-v1</code></li>
          <li><strong>BMP</strong>: <code>bmp-lsb-v1</code></li>
          <li><strong>WAV</strong>: <code>wav-lsb-v1</code></li>
        </ul>
      </Section>

      <Section id="cli" title="CLI examples" lead={siteContent.cliLead}>
        <ul class="command-list">
          {siteContent.cliExamples.map((example) => (
            <li class="card command-item">
              <CodeBlock code={example.command} />
              <p>{example.description}</p>
            </li>
          ))}
        </ul>
      </Section>

      <Section id="wpf" title="WPF desktop app" lead={siteContent.wpf.lead}>
        <p>Use the WPF app when you want a guided desktop workflow instead of CLI flags.</p>
        <ul>
          {siteContent.wpf.useCases.map((useCase) => (
            <li>{useCase}</li>
          ))}
        </ul>
        <p>Launch on Windows with:</p>
        <CodeBlock code={siteContent.wpf.launchCommand} />
        <p>Build on Windows with:</p>
        <CodeBlock code={siteContent.wpf.buildCommand} />
        <p>
          Full GUI documentation:
          <a href={siteContent.wpf.docsHref}>{siteContent.wpf.docsHref}</a>
        </p>
      </Section>

      <Section id="getting-started" title="Installation / getting started" lead={siteContent.installation.lead}>
        <CodeBlock code={siteContent.installation.commands.join('\n')} />
        <p>
          Full build and environment instructions:
          <a href={siteContent.installation.docsHref}>{siteContent.installation.docsHref}</a>
        </p>
      </Section>

      <Section id="download" title="Download / releases" lead={siteContent.ctas.lead}>
        <div class="actions">
          <a class="cta primary" href={siteContent.ctas.releases.href}>{siteContent.ctas.releases.label}</a>
          <a class="cta secondary" href={siteContent.ctas.repository.href}>{siteContent.ctas.repository.label}</a>
        </div>
      </Section>

      <Section id="roadmap" title="Roadmap" lead={siteContent.roadmapLead}>
        <ul class="roadmap-list">
          {siteContent.roadmap.map((phase) => (
            <li class="card">
              <h3>{phase.title}</h3>
              <p>{phase.summary}</p>
            </li>
          ))}
        </ul>
        <p>
          Detailed checklist:
          <a href="docs/roadmap.md">docs/roadmap.md</a>
        </p>
      </Section>

      <Section id="faq" title="Optional FAQ">
        <h3>Is StegoForge production-ready?</h3>
        <p>Core CLI/application flows for PNG/BMP/WAV are implemented and covered by tests.</p>
        <h3>Can I script it?</h3>
        <p>Yes. Use CLI JSON mode and mapped exit codes for deterministic automation behavior.</p>
      </Section>

      <Footer />
    </main>
  </body>
</html>
