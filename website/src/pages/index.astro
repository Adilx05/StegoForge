---
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    title: 'Layered architecture',
    description: 'Core contracts, application orchestration, and provider modules keep UI concerns separate from carrier logic.'
  },
  {
    title: 'Deterministic CLI contracts',
    description: 'Stable exit codes and JSON error shapes are designed for scripting and CI automation.'
  },
  {
    title: 'Policy-aware workflows',
    description: 'Embed and extract requests enforce compression/encryption policy validation before handler I/O.'
  },
  {
    title: 'Test-first reliability',
    description: 'Unit, integration, CLI, and WPF suites validate round trips and failure semantics.'
  }
];

const cliExamples = `dotnet run --project src/StegoForge.Cli -- embed --carrier in.png --payload secret.bin --out out.png

dotnet run --project src/StegoForge.Cli -- extract --carrier out.png --out recovered.bin

dotnet run --project src/StegoForge.Cli -- capacity --carrier in.wav --payload 65536 --compress auto

dotnet run --project src/StegoForge.Cli -- info --carrier out.png --json`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>StegoForge</title>
  </head>
  <body>
    <header>
      <nav aria-label="Section navigation">
        <a href="#hero">Hero</a>
        <a href="#overview">Overview</a>
        <a href="#features">Features</a>
        <a href="#formats">Formats</a>
        <a href="#cli">CLI</a>
        <a href="#wpf">WPF</a>
        <a href="#getting-started">Install</a>
        <a href="#download">Download</a>
        <a href="#roadmap">Roadmap</a>
        <a href="#faq">FAQ</a>
        <a href="#footer">Footer</a>
      </nav>
    </header>

    <main>
      <Hero />

      <Section id="overview" title="Project overview" lead="StegoForge is a modular .NET steganography platform focused on reliable embed/extract workflows across image and audio carriers.">
        <ul>
          <li>Core contracts in <code>StegoForge.Core</code> define service and payload models.</li>
          <li><code>StegoForge.Application</code> coordinates embed, extract, capacity, and info orchestration.</li>
          <li>Delivery surfaces include a scriptable CLI and a WPF desktop app.</li>
        </ul>
      </Section>

      <Section id="features" title="Feature highlights" lead="Current implementation emphasizes deterministic behavior and clear boundaries.">
        <FeatureGrid items={features} />
      </Section>

      <Section id="formats" title="Supported formats" lead="Production handlers currently wired through full workflows.">
        <ul>
          <li><strong>PNG</strong>: <code>png-lsb-v1</code></li>
          <li><strong>BMP</strong>: <code>bmp-lsb-v1</code></li>
          <li><strong>WAV</strong>: <code>wav-lsb-v1</code></li>
        </ul>
      </Section>

      <Section id="cli" title="CLI examples" lead="Canonical source-first command usage from the repository root.">
        <CodeBlock code={cliExamples} />
      </Section>

      <Section id="wpf" title="WPF desktop app" lead="StegoForge.Wpf provides a Windows workflow for embed/extract tasks with validation and operation-state feedback.">
        <p>
          The desktop app is intended for interactive use, while the CLI remains the primary automation surface.
          WPF build and test steps require Windows.
        </p>
      </Section>

      <Section id="getting-started" title="Installation / getting started" lead="Pinned .NET SDK: 10.0.100.">
        <ol>
          <li>Clone the repository and restore CLI/core projects.</li>
          <li>Build and run tests for unit, integration, and CLI suites.</li>
          <li>Run <code>dotnet run --project src/StegoForge.Cli -- help</code> to inspect commands.</li>
        </ol>
      </Section>

      <Section id="download" title="Download / releases" lead="Release artifacts include CLI tarballs and WPF zip packages with SHA-256 manifests and cosign signatures.">
        <p>
          Use GitHub Releases for versioned binaries and checksum/signature verification material.
          <a href="https://github.com/StegoForge/StegoForge/releases">Open releases</a>
        </p>
      </Section>

      <Section id="roadmap" title="Roadmap" lead="Near-term milestones focus on hardening, format expansion, and sustained contract stability.">
        <p>
          See <code>docs/roadmap.md</code> for implementation checklists and milestone-level tracking.
        </p>
      </Section>

      <Section id="faq" title="Optional FAQ">
        <h3>Is StegoForge production-ready?</h3>
        <p>Core CLI/application flows for PNG/BMP/WAV are implemented and covered by tests.</p>
        <h3>Can I script it?</h3>
        <p>Yes. Use CLI JSON mode and mapped exit codes for deterministic automation behavior.</p>
      </Section>

      <Footer />
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background: #0b1120;
    color: #f8fafc;
    line-height: 1.5;
  }

  header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(8px);
    background: rgba(2, 6, 23, 0.8);
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
  }

  nav {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.8rem 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
  }

  nav a {
    color: #cbd5e1;
    text-decoration: none;
    font-size: 0.92rem;
  }

  main {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  ul,
  ol {
    margin: 0;
    padding-left: 1.2rem;
    color: #cbd5e1;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9em;
  }

  h3 {
    margin-bottom: 0.25rem;
  }

  p {
    color: #cbd5e1;
  }
</style>
